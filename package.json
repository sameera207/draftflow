{
  "name": "draftflow",
  "version": "0.1.24",
  "description": "Markdown editor for Claude Code workflows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron --inspect .",
    "dist": "electron-builder --mac",
    "install-local": "npm run dist -- --dir --arm64 && rm -rf /Applications/Draftflow.app && cp -R dist/mac-arm64/Draftflow.app /Applications/Draftflow.app",
    "screenshots": "node scripts/take-screenshots.js",
    "guide": "node scripts/generate-guide.js",
    "docs": "npm run screenshots && npm run guide"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "playwright": "^1.44.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "marked": "^18.0.3"
  },
  "build": {
    "appId": "dev.draftflow.app",
    "productName": "Draftflow",
    "afterPack": "build/afterPack.js",
    "asarUnpack": [
      "hooks/**",
      "commands/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Draftflow ${version}",
      "backgroundColor": "#f7f4ef"
    },
    "publish": {
      "provider": "github",
      "owner": "sameera207",
      "repo": "draftflow"
    }
  }
}
